# =============================================================================
# .gitignore for STM32H747I-DISCO Music Keyboard project
# =============================================================================
# Place this file at the project root (same level as the .touchgfx file).
# =============================================================================


# -----------------------------------------------------------------------------
# Build artifacts — regenerated by every build, never check these in
# -----------------------------------------------------------------------------

# CubeIDE Debug / Release output folders (each contains hundreds of .o files)
**/Debug/
**/Release/

# Object files and intermediates
*.o
*.obj
*.d
*.lst
*.list
*.su          # stack usage reports
*.cyclo       # cyclomatic complexity reports

# Final firmware outputs
*.elf
*.bin
*.hex
*.map
*.srec

# Linker / assembler intermediates
*.a
*.lib


# -----------------------------------------------------------------------------
# CubeIDE / Eclipse workspace metadata
# -----------------------------------------------------------------------------

# Per-user IDE settings (path preferences, formatter config, etc.)
.settings/
.metadata/

# CubeIDE auto-generated backup files
.project.bak
.cproject.bak

# Launch configurations are sometimes user-specific (debug probe paths, etc.).
# Keep them if your team shares them; uncomment to ignore:
# *.launch


# -----------------------------------------------------------------------------
# TouchGFX build cache
# -----------------------------------------------------------------------------

# Designer's simulator build output
**/simulator/build/
**/simulator/obj/
**/simulator/bin/

# Designer's target build cache
**/target/build/
**/target/obj/

# Designer auto-generated backup of .touchgfx file
*.touchgfx.bak


# -----------------------------------------------------------------------------
# STM32CubeMX / CubeIDE temp files
# -----------------------------------------------------------------------------

# CubeMX log files
*.ioc.bak
.mxproject.bak


# -----------------------------------------------------------------------------
# OS-specific junk
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory
.Trash-*


# -----------------------------------------------------------------------------
# Editor backup files
# -----------------------------------------------------------------------------

*.swp
*.swo
*.bak
*.tmp
*.log
*.orig
*.rej

# VS Code workspace
.vscode/

# JetBrains IDEs
.idea/

# Vim
*.un~
Session.vim


# -----------------------------------------------------------------------------
# Things to KEEP in version control (commented examples)
# -----------------------------------------------------------------------------
# These are explicitly NOT ignored, listed here as reference:
#
#   .project              (CubeIDE project metadata — required to import)
#   .cproject             (CubeIDE build configuration)
#   .touchgfx             (TouchGFX project file)
#   *.ld                  (linker scripts)
#   *.ioc                 (CubeMX configuration)
#   CM7/ and CM4/         (source code)
#   Drivers/              (HAL drivers)
#   Middlewares/          (FreeRTOS, TouchGFX, LibJPEG)
#   assets/               (image source PNGs, fonts)
#   generated/            (TouchGFX-generated code — KEEP, so the project
#                          builds out of the box without forcing every cloner
#                          to install the exact same Designer version)

# Keep the prebuilt TouchGFX engine library (NOT an intermediate)
!**/touchgfx/lib/**/*.a